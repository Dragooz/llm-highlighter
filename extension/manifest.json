{
    "manifest_version": 3,
    "name": "LLM Highlighter",
    "version": "1.0.0",
    "description": "Highlight text → get AI-generated customer service reply",
    "permissions": ["activeTab", "storage", "scripting"],
    "host_permissions": ["<all_urls>"],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content_script.js"],
            "css": ["styles.css"]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "LLM Highlighter"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    }
}
