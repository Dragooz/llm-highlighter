{
    "manifest_version": 3,
    "name": "Swipey Chat",
    "version": "1.0.0",
    "description": "Floating AI chat for Pepper Cloud support agents",
    "permissions": ["activeTab", "storage", "scripting"],
    "host_permissions": ["<all_urls>"],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://app.peppercloud.com/*"],
            "js": ["content_script.js"],
            "css": ["styles.css"]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "LLM Highlighter"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    }
}
